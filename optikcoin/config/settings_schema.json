[
  {
    "name": "theme_info",
    "theme_name": "OptikCoin",
    "theme_version": "1.0.0",
    "theme_author": "Optik Platform",
    "theme_documentation_url": "https://docs.optik.com",
    "theme_support_url": "https://support.optik.com"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#0f172a",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#ffffff",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "accent_color",
        "default": "#3b82f6",
        "label": "t:labels.accent"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 8
      }
    ]
  },
  {
    "name": "t:sections.hero",
    "settings": [
      {
        "type": "text",
        "id": "hero_title",
        "label": "t:sections.hero.title",
        "default": "Welcome to OptikCoin"
      },
      {
        "type": "text",
        "id": "hero_subtitle",
        "label": "t:sections.hero.subtitle",
        "default": "Your Web3 Commerce Platform"
      },
      {
        "type": "text",
        "id": "hero_button_text",
        "label": "t:sections.hero.button_text",
        "default": "Get Started"
      },
      {
        "type": "url",
        "id": "hero_button_url",
        "label": "t:sections.hero.button_url",
        "default": "/collections/all"
      },
      {
        "type": "select",
        "id": "hero_background_style",
        "label": "t:sections.hero.background_style",
        "options": [
          {
            "value": "gradient-1",
            "label": "t:options.hero.gradient.blue"
          },
          {
            "value": "gradient-2",
            "label": "t:options.hero.gradient.purple"
          },
          {
            "value": "glass",
            "label": "t:options.hero.glass"
          }
        ],
        "default": "gradient-1"
      }
    ]
  },
  {
    "name": "t:sections.product_grid",
    "settings": [
      {
        "type": "range",
        "id": "products_per_row",
        "label": "t:sections.product_grid.products_per_row",
        "min": 1,
        "max": 6,
        "step": 1,
        "default": 4
      },
      {
        "type": "select",
        "id": "product_grid_view_mode",
        "label": "t:sections.product_grid.view_mode",
        "options": [
          {
            "value": "grid",
            "label": "t:options.product_grid.grid"
          },
          {
            "value": "list",
            "label": "t:options.product_grid.list"
          }
        ],
        "default": "grid"
      }
    ]
  }
]
